{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "spotify-pipeline-ADF"
		},
		"ADLS_Gen2_Connection_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ADLS_Gen2_Connection'"
		},
		"AzureSqlDatabaseConnection_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'AzureSqlDatabaseConnection'"
		},
		"ADLS_Gen2_Connection_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://spotifypipelinestorage.dfs.core.windows.net/"
		},
		"AzureSqlDatabaseConnection_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "spotify-project-server-uk.database.windows.net"
		},
		"AzureSqlDatabaseConnection_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "azureProjectdatabase"
		},
		"AzureSqlDatabaseConnection_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "adminutsav"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "spotify-pipeline-ADF_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ADLS_Gen2_Connection_accountKey": {
						"value": "[parameters('ADLS_Gen2_Connection_accountKey')]"
					},
					"AzureSqlDatabaseConnection_password": {
						"value": "[parameters('AzureSqlDatabaseConnection_password')]"
					},
					"ADLS_Gen2_Connection_properties_typeProperties_url": {
						"value": "[parameters('ADLS_Gen2_Connection_properties_typeProperties_url')]"
					},
					"AzureSqlDatabaseConnection_properties_typeProperties_server": {
						"value": "[parameters('AzureSqlDatabaseConnection_properties_typeProperties_server')]"
					},
					"AzureSqlDatabaseConnection_properties_typeProperties_database": {
						"value": "[parameters('AzureSqlDatabaseConnection_properties_typeProperties_database')]"
					},
					"AzureSqlDatabaseConnection_properties_typeProperties_userName": {
						"value": "[parameters('AzureSqlDatabaseConnection_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}